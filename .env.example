# ==========================================
#  Crypto Exchange Platform – Environment Variables
#  Copy this file to .env and fill in values
# ==========================================

# ---- Security ----
# Must be at least 256-bit (32 chars) for HS256
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY

# ---- PostgreSQL ----
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=auth_db

# ---- Spring Datasource (same creds, used by services) ----
SPRING_DATASOURCE_USERNAME=crypto_user
SPRING_DATASOURCE_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
