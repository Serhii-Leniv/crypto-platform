# ==========================================
#  Crypto Exchange Platform – Environment Variables
#  Copy to .env and fill in ALL required values before running docker compose.
#  Variables with no default will cause the service to refuse to start if unset.
# ==========================================

# ---- Security (REQUIRED — no defaults) ----
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=

# ---- PostgreSQL (REQUIRED — no defaults) ----
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=

# ---- PgAdmin (optional, defaults shown) ----
PGADMIN_EMAIL=admin@crypto.com
PGADMIN_PASSWORD=

# ---- Spring profiles: dev | prod ----
# "dev"  loads demo seed data (3 users alice/bob/charlie with password "Password1",
#        wallets, market data, open orders) + verbose SQL/DEBUG logging.
# "prod" no seed, INFO log level, no SQL logging.
SPRING_PROFILES_ACTIVE=dev

# ---- CORS (default: localhost frontend) ----
# Set to your deployed frontend URL in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Grafana (optional, defaults shown) ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=
