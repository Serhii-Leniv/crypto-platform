{
  "title": "Trading Engine Health",
  "uid": "trading-engine",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["crypto", "trading", "domain"],
  "panels": [
    {
      "id": 1,
      "title": "Orders placed / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(orders_placed_total[1m]))",
          "legendFormat": "placed/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 2,
      "title": "Orders rejected / sec (by reason)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (reason) (rate(orders_rejected_total[1m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3,
      "title": "Place order latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(orders_place_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(orders_place_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(orders_place_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p99 (ms)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 4,
      "title": "Match latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(matches_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(matches_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(matches_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p99 (ms)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "title": "Fills / sec (by symbol)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (symbol) (rate(matches_filled_total[1m]))",
          "legendFormat": "{{symbol}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "Settle latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(wallet_settle_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(wallet_settle_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(wallet_settle_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p99 (ms)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "STP skips (self-trade prevented)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(matches_stp_skips_total[5m]))",
          "legendFormat": "skips (5m)"
        }
      ]
    },
    {
      "id": 8,
      "title": "Open book depth (bids vs asks)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (symbol, side) (orderbook_depth)",
          "legendFormat": "{{symbol}} {{side}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Fees collected total (by currency)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (currency) (wallet_fees_collected_total)",
          "legendFormat": "{{currency}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Kafka consumer lag (market-data-group)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (topic, consumergroup) (kafka_consumer_fetch_manager_records_lag_max)",
          "legendFormat": "{{consumergroup}} - {{topic}}"
        }
      ]
    }
  ]
}
